{
    "name": "owp.graph",
    "version": "4.0.0",
    "description": "High performance graph plotter",
    "keywords": [
        "Open Web Project",
        "graph",
        "owp",
        "plot"
    ],
    "homepage": "https://github.com/AndreasArvidsson/OpenWebProject-graph",
    "bugs": {
        "url": "https://github.com/AndreasArvidsson/OpenWebProject-graph/issues"
    },
    "license": "MIT",
    "author": "Andreas Arvidsson",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/AndreasArvidsson/OpenWebProject-graph.git"
    },
    "files": [
        "dist/*",
        "images/*"
    ],
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./style.css": "./dist/index.css"
    },
    "scripts": {
        "clean": "rm -rf dist docs",
        "build": "npm run build:dist && npm run build:docs && npm run build:types",
        "build:types": "tsc",
        "build:dist": "vite build -- --bundle dist",
        "build:docs": "vite build -- --bundle docs",
        "typecheck": "tsc --noEmit -p . && tsc --noEmit -p demo",
        "lint": "npm run typecheck && npm run lint:ts && npm run lint:fmt",
        "lint:ts": "oxlint -c oxlint.config.mts --deny-warnings .",
        "lint:fmt": "oxfmt --check .",
        "fix": "npm run fix:ts && npm run fix:fmt",
        "fix:ts": "oxlint -c oxlint.config.mts --fix .",
        "fix:fmt": "oxfmt ."
    },
    "dependencies": {
        "spin.js": "^4.1.2"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "oxfmt": "^0.51.0",
        "oxlint": "^1.64.0",
        "oxlint-tsgolint": "^0.23.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.14"
    }
}
